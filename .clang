CompileFlags:
  Add:
    - -std=c++17
    - -DQT_CORE_LIB
    - -DQT_GUI_LIB
    - -DQT_WIDGETS_LIB
    - -DQT_NETWORK_LIB
    - -DQT_SERIALPORT_LIB
    - -DQT_WEBSOCKETS_LIB
    - -DQT_QML_LIB
    - -DQT_QUICK_LIB
    - -Wno-unknown-pragmas
    - -Wno-unused-parameter
    - -Wno-unused-variable
    - -Wno-ignored-attributes
    - -Wno-deprecated-declarations
  
  Remove:
    - -Werror
  
Diagnostics:
  Suppress:
    - "unused-parameter"
    - "unused-variable"
    - "missing-include"
    - "pp_including_mainfile_in_preamble"

Index:
  Background: Build